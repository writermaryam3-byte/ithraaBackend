    }
  ]
}

### Get Assignments (child & admin)
GET {{baseUrl}}/test-assignments
Authorization: Bearer {{token}}


### Get Result
GET {{baseUrl}}/tests/test-results/{{resultId}}
Authorization: Bearer {{token}}